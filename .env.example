# FORGE Gym Tracker - Firebase Configuration
# Follow these steps to get your Firebase config:
# 1. Go to https://console.firebase.google.com/
# 2. Click "Create a project" (or select existing)
# 3. Name it "forge-gym" (or any name)
# 4. Disable Google Analytics (optional)
# 5. After project is created, click the Web icon (</>) to add a web app
# 6. Register the app (nickname: "forge-gym-web")
# 7. Copy the firebaseConfig values below
# 8. Go to "Build" > "Realtime Database" > "Create Database"
# 9. Choose a location, then start in "test mode" (for development)
# 10. Copy the database URL (looks like: https://forge-gym-default-rtdb.firebaseio.com)

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
